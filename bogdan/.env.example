# VoidDB connection
VOIDDB_URL=http://localhost:7700
VOIDDB_TOKEN=your-token

# Auth
JWT_SECRET=change-me-32-chars-minimum-secret

# Telegram bot for OTP auth
TELEGRAM_BOT_TOKEN=your-bot-token
# Comma-separated Telegram user IDs allowed to access the workspace
BOGDAN_TELEGRAM_USER_IDS=123456789

# Mail (IMAP/SMTP)
MAIL_IMAP_HOST=mail.lowkey.su
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=mail.lowkey.su
MAIL_SMTP_PORT=587
MAIL_DOMAIN=lowkey.su

# AI (shared BitNet instance)
BITNET_URL=http://127.0.0.1:8080

# File storage
UPLOAD_DIR=./uploads

# Server
PORT=8090
