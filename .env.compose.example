APP_ENV=main
BACKEND_BIND_PORT=3101
FRONTEND_BIND_PORT=3100
N8N_BIND_PORT=5678
BITNET_BIND_PORT=8080
GENERIC_TIMEZONE=Asia/Yekaterinburg
NEXT_PUBLIC_API_URL=https://lowkey.su/api
NEXT_PUBLIC_SITE_URL=https://lowkey.su
LETSENCRYPT_ROOT_DIR=/etc/letsencrypt
BITNET_MODEL_REPO=1bitLLM/bitnet_b1_58-large
BITNET_MODEL_DIR_NAME=bitnet_b1_58-large
BITNET_QUANT_TYPE=i2_s
BITNET_USE_PRETUNED=1
BITNET_THREADS=4
BITNET_CTX_SIZE=4096
BITNET_TEMPERATURE=0.7
BITNET_N_PREDICT=1024
